{
  "name": "@lodd/mcp-server",
  "version": "0.1.15",
  "mcpName": "io.github.hholen/lodd-mcp-server",
  "description": "MCP server for Lodd \u2014 headless web analytics for agents",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./register": "./dist/register-tools.js",
